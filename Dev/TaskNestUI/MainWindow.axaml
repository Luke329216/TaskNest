<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="TaskNestUI.MainWindow"
        Width="900"
        Height="650"
        Title="TaskNest"
        Background="#0F172A">

    <Border>
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0"
                                 EndPoint="1,1">
                <GradientStop Color="#0F172A"
                              Offset="0"/>
                <GradientStop Color="#1E3A8A"
                              Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">

            <StackPanel Margin="30"
                        Spacing="20">

                <!-- Title -->
                <TextBlock Text="TaskNest"
                           FontSize="38"
                           FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="Organize your tasks beautifully"
                           FontSize="16"
                           Foreground="#CCCCCC"
                           HorizontalAlignment="Center"/>

                <!-- Input Box -->
                <Border Background="#1E293B"
                        CornerRadius="12"
                        Padding="15">

                    <Grid ColumnDefinitions="*,Auto,Auto"
                          ColumnSpacing="10">

                        <TextBox Grid.Column="0"
                                 Name="TaskInput"
                                 FontSize="16"
                                 Watermark="Add a task..."
                                 KeyDown="TaskInput_KeyDown"/>

                        <Button Grid.Column="1"
                                Content="Add"
                                Click="AddTaskToGeneral_Click"
                                MinWidth="80"/>

                        <Button Grid.Column="2"
                                Content="Undo"
                                Click="Undo_Click"
                                MinWidth="80"/>
                    </Grid>

                </Border>

                <TextBlock Text="Right-click categories and tasks for more options"
                           FontSize="13"
                           Foreground="#BBBBBB"
                           HorizontalAlignment="Center"/>

                <!-- Category Area -->
                <Border Background="#1E293B"
        CornerRadius="15"
        Padding="20">

    <Border.ContextMenu>
        <ContextMenu>
            <MenuItem Header="Add Category"
                      Click="AddCategoryFromEmptySpace_Click"/>
        </ContextMenu>
    </Border.ContextMenu>

                    <StackPanel Name="CategoryPanel"
                                Spacing="15">

                        <StackPanel.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Add Category"
                                          Click="AddCategoryFromEmptySpace_Click"/>
                            </ContextMenu>
                        </StackPanel.ContextMenu>

                    </StackPanel>

                </Border>

            </StackPanel>

        </ScrollViewer>
    </Border>

</Window>