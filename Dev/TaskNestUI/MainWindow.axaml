<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="TaskNestUI.MainWindow"
        Width="1200"
        Height="800"
        Title="TaskNest"
        Background="#0B1120">

    <TabControl TabStripPlacement="Bottom">

        <!-- TASKS -->

        <TabItem Header="Tasks">

            <Grid>

                <Border Background="#0B1120"/>

                <ScrollViewer VerticalScrollBarVisibility="Auto">

                    <StackPanel Margin="50"
                                Spacing="30">

                        <Border Background="#111827"
                                CornerRadius="16"
                                BorderBrush="#1E293B"
                                BorderThickness="1"
                                Padding="25">

                            <StackPanel Spacing="6">

                                <TextBlock Text="TaskNest"
                                           FontSize="42"
                                           FontWeight="Bold"
                                           Foreground="White"/>

                                <TextBlock Text="Your Productivity Workspace"
                                           FontSize="18"
                                           Foreground="#94A3B8"/>

                            </StackPanel>

                        </Border>

                        <Border Background="#111827"
                                CornerRadius="16"
                                BorderBrush="#1E293B"
                                BorderThickness="1"
                                Padding="25">

                            <StackPanel Spacing="15">

                                <TextBlock Text="Quick Add Task"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           Foreground="White"/>

                                <Grid ColumnDefinitions="*,Auto"
                                      ColumnSpacing="12">

                                    <TextBox Name="TaskInput"
                                             Height="44"
                                             Background="#0B1120"
                                             Foreground="White"
                                             BorderBrush="#334155"
                                             PlaceholderText="What needs to be done today?"/>

                                    <Button Grid.Column="1"
                                            Content="Add Task"
                                            Click="AddTaskToGeneral_Click"
                                            Background="#2563EB"
                                            Foreground="White"
                                            Height="44"
                                            MinWidth="120"/>

                                </Grid>

                                <Button Content="Undo Last Delete"
                                        Click="Undo_Click"
                                        Background="#334155"
                                        Foreground="White"
                                        HorizontalAlignment="Left"
                                        MinWidth="160"/>

                            </StackPanel>

                        </Border>

                        <Border Background="#111827"
                                CornerRadius="16"
                                BorderBrush="#1E293B"
                                BorderThickness="1"
                                Padding="20">

                            <StackPanel>

                                <TextBlock Text="Categories"
                                           FontSize="28"
                                           FontWeight="Bold"
                                           Foreground="White"/>

                                <TextBlock Text="Organize your tasks, manage progress and stay productive."
                                           Foreground="#94A3B8"/>

                            </StackPanel>

                        </Border>

                        <Border Name="CategoryContainer"
                                Background="#111827"
                                CornerRadius="16"
                                BorderBrush="#1E293B"
                                BorderThickness="1"
                                Padding="25">

                            <StackPanel Name="CategoryPanel"
                                        Spacing="20"/>

                        </Border>

                    </StackPanel>

                </ScrollViewer>

            </Grid>

        </TabItem>

        <!-- GUIDE -->

        <TabItem Header="Guide">

            <Grid Background="#0B1120">

                <ScrollViewer>

                    <StackPanel Margin="50"
                                Spacing="25">

                        <TextBlock Text="Welcome To TaskNest"
                                   FontSize="38"
                                   FontWeight="Bold"
                                   Foreground="White"/>

                        <TextBlock Text="Everything you need to manage your work in one place."
                                   FontSize="16"
                                   Foreground="#94A3B8"/>

                        <Border Background="#111827"
                                CornerRadius="16"
                                BorderBrush="#1E293B"
                                BorderThickness="1"
                                Padding="25">

                            <StackPanel Spacing="10">

                                <TextBlock Text="Getting Started"
                                           FontSize="22"
                                           FontWeight="Bold"
                                           Foreground="White"/>

                                <TextBlock Text="1. Create categories."
                                           Foreground="White"/>

                                <TextBlock Text="2. Add tasks."
                                           Foreground="White"/>

                                <TextBlock Text="3. Organize tasks."
                                           Foreground="White"/>

                                <TextBlock Text="4. Track progress."
                                           Foreground="White"/>

                            </StackPanel>

                        </Border>

                        <Border Background="#111827"
                                CornerRadius="16"
                                BorderBrush="#1E293B"
                                BorderThickness="1"
                                Padding="25">

                            <StackPanel Spacing="10">

                                <TextBlock Text="Productivity Tips"
                                           FontSize="22"
                                           FontWeight="Bold"
                                           Foreground="White"/>

                                <TextBlock Text="• Break large tasks into smaller tasks."
                                           Foreground="White"/>

                                <TextBlock Text="• Stay focused on today's work."
                                           Foreground="White"/>

                                <TextBlock Text="• Keep categories organized."
                                           Foreground="White"/>

                            </StackPanel>

                        </Border>

                    </StackPanel>

                </ScrollViewer>

            </Grid>

        </TabItem>

        <!-- SETTINGS -->

        <TabItem Header="Settings">

            <Grid Background="#0B1120">

                <ScrollViewer>

                    <StackPanel Margin="50"
                                Spacing="25">

                        <TextBlock Text="Settings"
                                   FontSize="38"
                                   FontWeight="Bold"
                                   Foreground="White"/>

                        <TextBlock Text="Customize your TaskNest experience."
                                   FontSize="16"
                                   Foreground="#94A3B8"/>

                        <Border Background="#111827"
                                CornerRadius="16"
                                BorderBrush="#1E293B"
                                BorderThickness="1"
                                Padding="25">

                            <StackPanel Spacing="15">

                                <TextBlock Text="Theme"
                                           FontSize="22"
                                           FontWeight="Bold"
                                           Foreground="White"/>

                                <TextBlock Text="Choose your preferred color scheme."
                                           Foreground="#94A3B8"/>

                                <ComboBox Name="ThemePicker"
                                          SelectedIndex="0">

                                    <ComboBoxItem Content="🌑 Midnight"/>
                                    <ComboBoxItem Content="🌊 Ocean Blue"/>
                                    <ComboBoxItem Content="🌌 Purple Night"/>
                                    <ComboBoxItem Content="🌲 Emerald"/>
                                    <ComboBoxItem Content="☀ Light Mode"/>

                                </ComboBox>

                            </StackPanel>

                        </Border>

                        <Border Background="#111827"
                                CornerRadius="16"
                                BorderBrush="#1E293B"
                                BorderThickness="1"
                                Padding="25">

                            <StackPanel Spacing="10">

                                <TextBlock Text="About TaskNest"
                                           FontSize="22"
                                           FontWeight="Bold"
                                           Foreground="White"/>

                                <TextBlock Text="Version 2.0"
                                           Foreground="White"/>

                                <TextBlock Text="Built with Avalonia UI"
                                           Foreground="#94A3B8"/>

                                <TextBlock Text="TaskNest helps you organize tasks, categories and productivity in one place."
                                           Foreground="#94A3B8"
                                           TextWrapping="Wrap"/>

                            </StackPanel>

                        </Border>

                    </StackPanel>

                </ScrollViewer>

            </Grid>

        </TabItem>

    </TabControl>

</Window>