<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="TaskNestUI.MainWindow"
        Width="900"
        Height="650"
        Title="TaskNest"
        Background="#0F172A">

    <TabControl TabStripPlacement="Bottom">

        <!-- ✅ TASKS TAB -->
        <TabItem Header="Tasks">

            <Border>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#2D1B69" Offset="0.0"/>
                        <GradientStop Color="#0F1B45" Offset="0.5"/>
                        <GradientStop Color="#0A0F24" Offset="1.0"/>
                    </LinearGradientBrush>
                </Border.Background>

                <ScrollViewer VerticalScrollBarVisibility="Auto">

                    <StackPanel Margin="30" Spacing="20">

                        <!-- Title -->
                        <TextBlock Text="TaskNest"
                                   FontSize="38"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"/>

                        <!-- Input -->
                        <Border Background="#1E293B80"
                                CornerRadius="12"
                                Padding="15">

                            <Grid ColumnDefinitions="*,Auto,Auto"
                                  ColumnSpacing="10">

                                <TextBox Name="TaskInput"
                                         Foreground="White"
                                         Background="#111827"
                                         PlaceholderText="Add a task..."/>

                                <Button Grid.Column="1"
                                        Content="Add"
                                        Click="AddTaskToGeneral_Click"
                                        Background="#2563EB"
                                        Foreground="White"/>

                                <Button Grid.Column="2"
                                        Content="Undo"
                                        Click="Undo_Click"
                                        Background="#374151"
                                        Foreground="White"/>

                            </Grid>

                        </Border>

                        <!-- Categories -->
                        <Border Background="#1E293B80"
                                CornerRadius="15"
                                Padding="20"
                                Name="CategoryContainer">

                            <StackPanel Name="CategoryPanel"
                                        Spacing="15"/>

                        </Border>

                    </StackPanel>

                </ScrollViewer>

            </Border>

        </TabItem>

        <!-- ✅ GUIDE TAB -->
        <TabItem Header="Guide">

            <ScrollViewer>
                <StackPanel Margin="25" Spacing="15">

                    <TextBlock Text="How to Use TaskNest"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="White"/>

                    <TextBlock Text="• Add tasks using the box at the top (or press Enter)."
                               Foreground="White"/>

                    <TextBlock Text="• Right‑click empty space → Add Category."
                               Foreground="White"/>

                    <TextBlock Text="• Right‑click a category → Add Task."
                               Foreground="White"/>

                    <TextBlock Text="• Right‑click a task → Move, Priority, Due Date."
                               Foreground="White"/>

                    <TextBlock Text="• Check a task → moves it to Completed."
                               Foreground="White"/>

                    <TextBlock Text="• Overdue tasks will show ⚠️."
                               Foreground="White"/>

                    <TextBlock Text="• Use Undo to bring back deleted tasks."
                               Foreground="White"/>

                </StackPanel>
            </ScrollViewer>

        </TabItem>

    </TabControl>

</Window>
