<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="TaskNestUI.MainWindow"
        Width="900"
        Height="650"
        Title="TaskNest"
        Background="#0F172A">

    <Border>
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#1F2937" Offset="0"/>
                <GradientStop Color="#111827" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>

        <ScrollViewer VerticalScrollBarVisibility="Auto">

            <StackPanel Margin="30" Spacing="20">

                <!-- Title -->
                <TextBlock Text="TaskNest"
                           FontSize="38"
                           FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"/>

                <!-- Input -->
                <Border Background="#1E293B"
                        CornerRadius="12"
                        Padding="15">

                    <Grid ColumnDefinitions="*,Auto,Auto"
                          ColumnSpacing="10">

                        <TextBox Name="TaskInput"
                                 Foreground="White"
                                 Background="#111827"
                                 PlaceholderText="Add a task..."
                                 KeyDown="TaskInput_KeyDown"/>

                        <Button Grid.Column="1"
                                Content="Add"
                                Background="#2563EB"
                                Foreground="White"/>

                        <Button Grid.Column="2"
                                Content="Undo"
                                Background="#374151"
                                Foreground="White"/>
                    </Grid>

                </Border>

                <!-- Categories -->
                <Border Background="#1E293B"
                        CornerRadius="15"
                        Padding="20"
                        Name="CategoryContainer">

                    <StackPanel Name="CategoryPanel"
                                Spacing="15"/>

                </Border>

            </StackPanel>

        </ScrollViewer>

    </Border>

</Window>